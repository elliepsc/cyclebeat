# Groq / OpenAI-compatible client
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.groq.com/openai/v1
MODEL_NAME=llama-3.3-70b-versatile

# Spotify
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://localhost:8888/callback
SPOTIFY_CACHE_PATH=.spotify_cache

# Qdrant — local (Docker)
QDRANT_HOST=localhost
QDRANT_PORT=6333

# Qdrant Cloud (optional — set these to use Qdrant Cloud instead of local)
# Get a free cluster at https://cloud.qdrant.io
# When QDRANT_URL is set, QDRANT_HOST/PORT are ignored
QDRANT_URL=
QDRANT_API_KEY=
COLLECTION_NAME=cycling_patterns

# App
APP_PORT=8501
TZ=Europe/Paris
RUN_TIMEZONE_CHECK=false

# Optional local services
POSTGRES_DB=cyclebeat
POSTGRES_USER=cyclebeat
POSTGRES_PASSWORD=change-me
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me
GRAFANA_SECRET_KEY=change-me
